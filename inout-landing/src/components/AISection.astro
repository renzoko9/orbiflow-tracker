---

---

<section class="otto" id="otto">
  <div class="wrap">
    <div class="eyebrow-row reveal on-dark">Asistente con IA &middot; Otto</div>
    <h2 class="section__h2 reveal reveal--lag-1 otto__h">
      Mandale una foto.<br />Otto la registra.
    </h2>
    <p class="section__lead reveal reveal--lag-2 otto__lead">
      Saca foto a tu boleta o escribele en lenguaje normal. Otto detecta el
      comercio, el monto, la categoria y la fecha, y te propone el movimiento.
      Tu confirmas con un toque. Tambien puedes preguntarle como van tus
      finanzas.
    </p>

    <div class="otto__grid reveal reveal--lag-3">
      <div class="otto__media">
        <div class="otto__stage">
          <div class="phone phone--1">
            <div class="phone__notch"></div>
            <div class="phone__screen">
              <img
                src="/screenshots/app-mobile-screenshot.jpeg"
                alt="Chat con Otto: foto de un recibo y propuesta de registro"
                loading="lazy"
              />
            </div>
          </div>

          <div class="phone phone--2">
            <div class="phone__notch"></div>
            <div class="phone__screen">
              <img
                src="/screenshots/app-mobile-screenshot-3.jpeg"
                alt="Chat con Otto respondiendo una consulta sobre tus finanzas"
                loading="lazy"
              />
            </div>
          </div>
        </div>

        <div class="otto__dots" aria-hidden="true">
          <span class="otto__dot otto__dot--a"></span>
          <span class="otto__dot otto__dot--b"></span>
        </div>
      </div>

      <div class="otto__features">
        <article class="ofeat">
          <div class="ofeat__icon green"><i data-lucide="camera"></i></div>
          <div>
            <h3>Foto del recibo, y listo</h3>
            <p>
              Sacale foto a tu boleta o voucher. Otto lee comercio, monto y
              fecha, asigna categoria y arma el movimiento. Tu solo revisas y
              confirmas.
            </p>
          </div>
        </article>

        <article class="ofeat">
          <div class="ofeat__icon navy">
            <i data-lucide="message-square"></i>
          </div>
          <div>
            <h3>Hablale como a una persona</h3>
            <p>
              "Gaste 20 soles en uber" o "como voy este mes". Otto entiende el
              lenguaje natural y responde con tus numeros reales, en una
              interfaz limpia y ordenada.
            </p>
          </div>
        </article>

        <article class="ofeat">
          <div class="ofeat__icon blue"><i data-lucide="sparkles"></i></div>
          <div>
            <h3>Cada vez mas capaz</h3>
            <p>
              El chat esta en mejora continua. Poco a poco va a soportar
              consultas mas complejas sobre tus finanzas, manteniendo la misma
              simpleza.
            </p>
            <span class="ofeat__tag">En desarrollo activo</span>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .otto {
    background: var(--color-navy);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }
  .otto::before {
    content: "";
    position: absolute;
    top: 56px;
    right: var(--gutter);
    width: 180px;
    height: 180px;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.16) 1.5px,
      transparent 1.6px
    );
    background-size: 16px 16px;
    opacity: 0.6;
    pointer-events: none;
    z-index: 1;
  }
  .otto .wrap {
    position: relative;
    z-index: 2;
  }
  .otto__h {
    color: var(--color-white);
  }
  .otto__lead {
    color: var(--color-white-70);
  }

  .otto__grid {
    margin-top: 56px;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }
  @media (max-width: 980px) {
    .otto__grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }
  }

  /* Dos iPhones que se intercambian en 3D */
  .otto__media {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 26px;
  }
  .otto__stage {
    position: relative;
    width: 100%;
    max-width: 300px;
    aspect-ratio: 9 / 19.5;
    perspective: 1600px;
  }
  .phone {
    position: absolute;
    inset: 0;
    background: #0e1430;
    border-radius: 44px;
    padding: 10px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
    transform-origin: center center;
    will-change: transform, opacity;
    animation: otto-swap 9s var(--ease-in-out) infinite;
  }
  /* Cada uno sale por un lado distinto y se desplazan en paralelo (no se
     atraviesan por el centro). --shift = cuanto se corren a los lados. */
  .phone {
    --shift: 150px;
  }
  .phone--1 {
    --dir: 1;
  }
  .phone--2 {
    --dir: -1;
    animation-delay: -4.5s;
  }
  @media (max-width: 600px) {
    .phone {
      --shift: 96px;
    }
  }
  .phone__notch {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 92px;
    height: 24px;
    background: #0e1430;
    border-radius: 999px;
    z-index: 3;
  }
  .phone__screen {
    width: 100%;
    height: 100%;
    border-radius: 36px;
    overflow: hidden;
    background: var(--color-cream);
  }
  .phone__screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  /* Al frente: centrado y plano. Atras: emerge desde el costado, girado,
     mas chico y en profundidad (translateZ negativo). Mismo keyframe para los
     dos; el segundo va medio ciclo desfasado, asi se cruzan al intercambiarse. */
  @keyframes otto-swap {
    0%,
    38% {
      transform: translateX(0) translateZ(0) rotateY(0deg) scale(1);
      opacity: 1;
      z-index: 2;
    }
    44% {
      z-index: 1;
    }
    50%,
    88% {
      transform: translateX(calc(var(--shift) * var(--dir))) translateZ(-200px)
        rotateY(calc(-24deg * var(--dir))) scale(0.88);
      opacity: 0.55;
      z-index: 1;
    }
    94% {
      z-index: 2;
    }
    100% {
      transform: translateX(0) translateZ(0) rotateY(0deg) scale(1);
      opacity: 1;
      z-index: 2;
    }
  }

  /* Indicador de paso */
  .otto__dots {
    display: flex;
    gap: 8px;
  }
  .otto__dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.35);
  }
  .otto__dot--a {
    animation: otto-dot-a 9s var(--ease-in-out) infinite;
  }
  .otto__dot--b {
    animation: otto-dot-b 9s var(--ease-in-out) infinite;
  }
  @keyframes otto-dot-a {
    0%,
    38% {
      background: var(--color-green);
    }
    50%,
    100% {
      background: rgba(255, 255, 255, 0.35);
    }
  }
  @keyframes otto-dot-b {
    0%,
    46% {
      background: rgba(255, 255, 255, 0.35);
    }
    50%,
    88% {
      background: var(--color-green);
    }
    100% {
      background: rgba(255, 255, 255, 0.35);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone {
      animation: none;
    }
    .phone--2 {
      transform: translateX(-150px) translateZ(-200px) rotateY(24deg)
        scale(0.88);
      opacity: 0.55;
    }
  }

  /* Feature list */
  .otto__features {
    display: flex;
    flex-direction: column;
  }
  .ofeat {
    border-top: 1px solid var(--color-white-15);
    padding: 26px 0;
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: 20px;
    align-items: start;
    transition: transform 140ms var(--ease-out);
  }
  .ofeat:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .ofeat:hover {
    transform: translateX(4px);
  }
  .ofeat__icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: grid;
    place-items: center;
  }
  .ofeat__icon.green {
    background: var(--color-green);
    color: var(--color-ink);
  }
  .ofeat__icon.navy {
    background: var(--color-cream);
    color: var(--color-navy-2);
  }
  .ofeat__icon.blue {
    background: var(--color-blue);
    color: var(--color-white);
  }
  .ofeat__icon :global(.lucide) {
    width: 24px;
    height: 24px;
    stroke-width: 2;
  }
  .ofeat h3 {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin: 4px 0 8px;
    color: var(--color-white);
  }
  .ofeat p {
    font-size: 15px;
    color: var(--color-white-60);
    line-height: 1.5;
  }
  .ofeat__tag {
    display: inline-block;
    margin-top: 14px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 11px;
    border-radius: 8px;
    background: var(--color-green-soft);
    color: var(--color-green-deep);
  }
</style>
