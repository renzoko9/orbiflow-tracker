---

---

<section id="descargar" class="cta-section">
  <div class="wrap">
    <div class="cta-banner reveal">
      <div class="cta-banner__ghost" aria-hidden="true">INOUT</div>

      <div class="cta-banner__mark">
        <img src="/logo-mark.svg" alt="" class="cta-banner__logo" />
      </div>

      <div class="cta-banner__copy">
        <span class="cta-banner__eyebrow"
          >Aplicacion fintech &middot; IA + WhatsApp</span
        >
        <h2>Tu dinero,<br />bajo control.</h2>
        <p>Registra ingresos y gastos en segundos. Sin complicaciones.</p>
      </div>

      <div class="cta-banner__buttons">
        <a href="#" class="store-badge" aria-label="Descargalo en la App Store">
          <img class="store-badge__icon" src="/apple-logo.png" alt="" />
          <span class="store-badge__text">
            <span class="store-badge__small">Descargalo en la</span>
            <span class="store-badge__name">App Store</span>
          </span>
        </a>
        <a href="#" class="store-badge" aria-label="Descargalo en Google Play">
          <img class="store-badge__icon" src="/google-play.png" alt="" />
          <span class="store-badge__text">
            <span class="store-badge__small">Descargalo en</span>
            <span class="store-badge__name">Google Play</span>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-top: 0;
  }

  .cta-banner {
    position: relative;
    overflow: hidden;
    background: var(--color-primary-green);
    color: var(--color-ink);
    border-radius: var(--radius-card);
    padding: clamp(48px, 7vw, 88px);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .cta-banner__mark {
    width: 116px;
    height: 116px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    background: var(--color-sage);
    border-radius: 28px;
    box-shadow: 0 16px 40px rgba(14, 15, 12, 0.18);
    z-index: 2;
  }
  .cta-banner__logo {
    width: 66px;
    height: auto;
    display: block;
  }
  .cta-banner__copy {
    z-index: 2;
    position: relative;
  }
  .cta-banner__eyebrow {
    color: rgba(14, 15, 12, 0.6);
    margin-bottom: 12px;
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .cta-banner__copy h2 {
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1;
    margin: 0;
  }
  .cta-banner__copy p {
    margin-top: 14px;
    font-size: 16px;
    color: rgba(14, 15, 12, 0.7);
    max-width: 480px;
  }
  .cta-banner__buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    z-index: 2;
  }
  .store-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #000000;
    color: var(--color-white-pure);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 14px;
    padding: 11px 22px;
    transition:
      transform 140ms var(--ease-out),
      box-shadow 140ms var(--ease-out);
  }
  .store-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 26px rgba(14, 15, 12, 0.28);
  }
  .store-badge__icon {
    height: 26px;
    flex-shrink: 0;
    display: block;
  }
  .store-badge__text {
    display: flex;
    flex-direction: column;
    line-height: 1.12;
  }
  .store-badge__small {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.01em;
    opacity: 0.82;
  }
  .store-badge__name {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .cta-banner__ghost {
    position: absolute;
    right: -2%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(180px, 22vw, 320px);
    line-height: 0.85;
    letter-spacing: -0.02em;
    color: rgba(14, 15, 12, 0.12);
    pointer-events: none;
    z-index: 1;
    user-select: none;
  }
  @media (max-width: 900px) {
    .cta-banner {
      grid-template-columns: 1fr;
      padding: 36px;
    }
    .cta-banner__mark {
      width: 88px;
      height: 88px;
      border-radius: 22px;
    }
    .cta-banner__logo {
      width: 50px;
      height: auto;
    }
  }
</style>
