---

<section id="proximamente" class="cta-section">
  <div class="wrap">
    <div class="cta reveal">
      <div class="cta__dots" aria-hidden="true"></div>
      <div class="cta__ghost display" aria-hidden="true">JUL 1</div>

      <div class="cta__inner">
        <div class="cta__mark">
          <img src="/logo-mark.svg" alt="" />
        </div>

        <span class="cta__eyebrow">
          <span class="dot"></span>
          Proximamente &middot; en desarrollo
        </span>

        <h2 class="cta__title">
          Disponible el<br /><span class="accent">1 de julio de 2026.</span>
        </h2>

        <p class="cta__lead">
          Estamos terminando la primera version para probar. Vuelve el dia del
          lanzamiento: los enlaces de descarga apareceran aqui.
        </p>

        <div
          class="cta__count"
          data-countdown
          aria-label="Cuenta regresiva al lanzamiento"
        >
          <div class="cd">
            <span class="cd__n" data-cd="days">--</span>
            <span class="cd__u">dias</span>
          </div>
          <span class="cd__sep">:</span>
          <div class="cd">
            <span class="cd__n" data-cd="hours">--</span>
            <span class="cd__u">hrs</span>
          </div>
          <span class="cd__sep">:</span>
          <div class="cd">
            <span class="cd__n" data-cd="mins">--</span>
            <span class="cd__u">min</span>
          </div>
          <span class="cd__sep">:</span>
          <div class="cd">
            <span class="cd__n" data-cd="secs">--</span>
            <span class="cd__u">seg</span>
          </div>
        </div>

        <div class="cta__badges">
          <div class="store-badge" aria-label="App Store - proximamente">
            <img class="store-badge__icon" src="/apple-logo.png" alt="" />
            <span class="store-badge__text">
              <span class="store-badge__small">Proximamente en</span>
              <span class="store-badge__name">App Store</span>
            </span>
          </div>
          <div class="store-badge" aria-label="Google Play - proximamente">
            <img class="store-badge__icon" src="/google-play.png" alt="" />
            <span class="store-badge__text">
              <span class="store-badge__small">Proximamente en</span>
              <span class="store-badge__name">Google Play</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-top: 0;
  }

  .cta {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: var(--color-navy);
    color: var(--color-white);
    border-radius: var(--radius-card);
    padding: clamp(48px, 7vw, 96px) clamp(24px, 5vw, 64px);
    text-align: center;
  }

  .cta__inner {
    position: relative;
    z-index: 2;
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta__mark {
    width: 72px;
    height: 72px;
    display: grid;
    place-items: center;
    background: var(--color-cream);
    border-radius: 20px;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.35);
  }
  .cta__mark img {
    width: 42px;
    height: auto;
    display: block;
  }

  .cta__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 28px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white-60);
  }
  .cta__eyebrow .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-green);
    animation: inout-blink 1.6s var(--ease-in-out) infinite;
  }

  .cta__title {
    margin-top: 16px;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: var(--color-white);
  }
  .cta__title .accent {
    color: var(--color-green);
  }

  .cta__lead {
    margin-top: 18px;
    max-width: 460px;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-white-70);
  }

  /* Countdown (mismo lenguaje que el hero) */
  .cta__count {
    margin-top: 40px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(10px, 2vw, 18px);
  }
  .cd {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 62px;
  }
  .cd__n {
    font-family: var(--font-body);
    font-weight: 800;
    font-feature-settings: "tnum" 1;
    font-size: clamp(38px, 5vw, 58px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-white);
  }
  .cd__u {
    margin-top: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-white-60);
  }
  .cd__sep {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(30px, 4vw, 46px);
    line-height: 1;
    color: var(--color-green);
    padding-top: 2px;
  }
  @media (max-width: 480px) {
    .cd {
      min-width: 0;
      flex: 1;
    }
    .cta__count {
      gap: 6px;
    }
  }

  /* Store badges (estado proximamente, no clicables) */
  .cta__badges {
    margin-top: 40px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .store-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--color-white-10);
    color: var(--color-white);
    border: 1px solid var(--color-white-15);
    border-radius: var(--radius-btn);
    padding: 11px 20px;
  }
  .store-badge__icon {
    height: 24px;
    flex-shrink: 0;
    display: block;
  }
  .store-badge__text {
    display: flex;
    flex-direction: column;
    line-height: 1.12;
    text-align: left;
  }
  .store-badge__small {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-white-60);
  }
  .store-badge__name {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Texturas de fondo (coherentes con hero / otto) */
  .cta__dots {
    position: absolute;
    top: 32px;
    left: 50%;
    transform: translateX(-50%);
    width: 180px;
    height: 120px;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.16) 1.5px,
      transparent 1.6px
    );
    background-size: 16px 16px;
    opacity: 0.5;
    pointer-events: none;
    z-index: 1;
  }
  .cta__ghost {
    position: absolute;
    right: 2%;
    bottom: 8%;
    font-size: clamp(160px, 24vw, 320px);
    line-height: 0.82;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.05);
    pointer-events: none;
    z-index: 1;
    user-select: none;
  }
</style>
