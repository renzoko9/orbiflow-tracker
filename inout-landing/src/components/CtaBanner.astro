---
import LogoMark from "./LogoMark.astro";
---
<section id="descargar" class="cta-section">
  <div class="wrap">
    <div class="cta-banner reveal">
      <div class="cta-banner__ghost" aria-hidden="true">INOUT</div>

      <div class="cta-banner__mark">
        <LogoMark />
      </div>

      <div class="cta-banner__copy">
        <span class="cta-banner__eyebrow">Aplicacion fintech &middot; IA + WhatsApp</span>
        <h2>Tu dinero,<br />bajo control.</h2>
        <p>Registra ingresos y gastos en segundos. Sin complicaciones.</p>
      </div>

      <div class="cta-banner__buttons">
        <a href="#" class="btn btn--ink">Descargar para iOS <i data-lucide="apple"></i></a>
        <a href="#" class="btn btn--ink">Descargar para Android <i data-lucide="smartphone"></i></a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section { padding-top: 0; }

  .cta-banner {
    position: relative;
    overflow: hidden;
    background: var(--color-primary-green);
    color: var(--color-ink);
    border-radius: var(--radius-card);
    padding: clamp(48px, 7vw, 88px);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .cta-banner__mark {
    width: 88px;
    height: 100px;
    color: var(--color-ink);
    background: transparent;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    border-right: 1px solid rgba(14, 15, 12, 0.2);
    padding-right: clamp(24px, 4vw, 56px);
  }
  .cta-banner__mark :global(svg) {
    width: 64px;
    height: 76px;
  }
  .cta-banner__copy {
    z-index: 2;
    position: relative;
  }
  .cta-banner__eyebrow {
    color: rgba(14, 15, 12, 0.6);
    margin-bottom: 12px;
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .cta-banner__copy h2 {
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1;
    margin: 0;
  }
  .cta-banner__copy p {
    margin-top: 14px;
    font-size: 16px;
    color: rgba(14, 15, 12, 0.7);
    max-width: 480px;
  }
  .cta-banner__buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    z-index: 2;
  }
  .cta-banner__ghost {
    position: absolute;
    right: -2%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(180px, 22vw, 320px);
    line-height: 0.85;
    letter-spacing: -0.02em;
    color: rgba(14, 15, 12, 0.12);
    pointer-events: none;
    z-index: 1;
    user-select: none;
  }
  @media (max-width: 900px) {
    .cta-banner {
      grid-template-columns: 1fr;
      padding: 36px;
    }
    .cta-banner__mark {
      border-right: 0;
      border-bottom: 1px solid rgba(14, 15, 12, 0.2);
      padding: 0 0 24px;
      width: auto;
      height: auto;
    }
    .cta-banner__mark :global(svg) {
      width: 48px;
      height: 56px;
    }
  }
</style>
