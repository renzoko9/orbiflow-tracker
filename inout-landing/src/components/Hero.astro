---

---

<section class="hero" id="top">
  <div class="hero__dots"></div>
  <div class="hero__ghost">INOUT</div>

  <div class="wrap hero__inner">
    <div class="hero__chip">
      <span class="dot"></span>
      En desarrollo &middot; Primera version el 1 de julio
    </div>

    <h1 class="hero__h1">
      Sabes en qu&eacute; se va<br />tu plata? <span class="accent"
        >Sin esfuerzo.</span
      >
    </h1>

    <p class="hero__sub">
      INOUT es una app de finanzas personales con <b>Otto</b>, un asistente que
      registra tus gastos por ti: mandale una foto del recibo o escribele en
      lenguaje normal. La estamos construyendo &mdash; esto es lo que ya
      funciona.
    </p>

    <div class="hero__ctas">
      <a href="#otto" class="btn btn--green">
        Conoce a Otto <i data-lucide="arrow-right"></i>
      </a>
      <a href="#producto" class="btn btn--ghost-on-dark">Ver el producto</a>
    </div>

    <div
      class="hero__count"
      data-countdown
      aria-label="Cuenta regresiva al lanzamiento"
    >
      <div class="hero__count-label">
        Lanzamiento &middot; 1 de julio de 2026
      </div>
      <div class="hero__count-grid">
        <div class="cd">
          <span class="cd__n" data-cd="days">--</span><span class="cd__u"
            >dias</span>
        </div>
        <span class="cd__sep">:</span>
        <div class="cd">
          <span class="cd__n" data-cd="hours">--</span><span class="cd__u"
            >hrs</span>
        </div>
        <span class="cd__sep">:</span>
        <div class="cd">
          <span class="cd__n" data-cd="mins">--</span><span class="cd__u"
            >min</span>
        </div>
        <span class="cd__sep">:</span>
        <div class="cd">
          <span class="cd__n" data-cd="secs">--</span><span class="cd__u"
            >seg</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero__cue" aria-hidden="true">
    Scroll
    <span class="arrow"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-navy);
    color: var(--color-white);
    overflow: hidden;
    padding: clamp(64px, 10vw, 124px) 0 clamp(88px, 12vw, 148px);
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 940px;
  }
  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 32px;
    padding: 0 14px;
    border: 1px solid var(--color-white-15);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white-70);
    margin-bottom: 34px;
  }
  .hero__chip .dot {
    width: 6px;
    height: 6px;
    background: var(--color-green);
    border-radius: 999px;
  }
  .hero__h1 {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(48px, 8vw, 110px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    margin: 0;
    text-wrap: balance;
    color: var(--color-white);
  }
  .hero__h1 .accent {
    color: var(--color-green);
  }
  .hero__sub {
    margin-top: 32px;
    max-width: 620px;
    font-size: clamp(17px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--color-white-70);
  }
  .hero__sub b {
    color: var(--color-white);
    font-weight: 700;
  }
  .hero__ctas {
    margin-top: 40px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero__ghost {
    position: absolute;
    right: -2vw;
    bottom: -8%;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(280px, 38vw, 540px);
    line-height: 0.78;
    color: var(--color-white);
    opacity: 0.06;
    pointer-events: none;
    letter-spacing: -0.02em;
    user-select: none;
    z-index: 1;
  }
  .hero__dots {
    position: absolute;
    top: 64px;
    right: var(--gutter);
    width: 140px;
    height: 140px;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.18) 1.5px,
      transparent 1.6px
    );
    background-size: 14px 14px;
    opacity: 0.55;
    pointer-events: none;
    z-index: 1;
  }
  @media (max-width: 720px) {
    .hero__dots {
      display: none;
    }
  }

  /* Countdown */
  .hero__count {
    position: relative;
    z-index: 2;
    margin-top: clamp(48px, 8vw, 84px);
    padding-top: 30px;
    border-top: 1px solid var(--color-white-15);
    max-width: 520px;
  }
  .hero__count-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white-60);
    margin-bottom: 18px;
  }
  .hero__count-grid {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .cd {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-width: 64px;
  }
  .cd__n {
    font-family: var(--font-body);
    font-weight: 800;
    font-feature-settings: "tnum" 1;
    font-size: clamp(40px, 5vw, 60px);
    line-height: 1;
    color: var(--color-white);
    letter-spacing: -0.03em;
  }
  .cd__u {
    margin-top: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-white-60);
  }
  .cd__sep {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1;
    color: var(--color-green);
    padding-top: 2px;
  }
  @media (max-width: 480px) {
    .cd {
      min-width: 0;
      flex: 1;
    }
    .hero__count-grid {
      gap: 8px;
    }
  }

  /* Staggered entry */
  .hero__chip,
  .hero__h1,
  .hero__sub,
  .hero__ctas,
  .hero__count {
    opacity: 0;
    animation: inout-rise 720ms var(--ease-out) forwards;
  }
  .hero__chip {
    animation-delay: 60ms;
  }
  .hero__h1 {
    animation-delay: 140ms;
  }
  .hero__sub {
    animation-delay: 320ms;
  }
  .hero__ctas {
    animation-delay: 440ms;
  }
  .hero__count {
    animation-delay: 560ms;
  }

  .hero__ghost {
    opacity: 0.06;
    animation:
      inout-ghost-in 1400ms var(--ease-out) 200ms both,
      inout-drift 22s var(--ease-in-out) 200ms infinite;
  }
  .hero__chip .dot {
    animation: inout-blink 1.6s var(--ease-in-out) infinite;
  }

  .hero__cue {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: var(--color-white-60);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    animation: inout-fade 1s var(--ease-out) 900ms both;
  }
  .hero__cue .arrow {
    width: 1px;
    height: 36px;
    background: var(--color-white-15);
    position: relative;
    animation: inout-bounce-down 1.8s var(--ease-in-out) infinite;
  }
  .hero__cue .arrow::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 7px;
    height: 7px;
    border-right: 1px solid var(--color-white-60);
    border-bottom: 1px solid var(--color-white-60);
    transform: translateX(-50%) rotate(45deg);
  }
  @media (max-width: 720px) {
    .hero__cue {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__chip,
    .hero__h1,
    .hero__sub,
    .hero__ctas,
    .hero__count,
    .hero__cue {
      opacity: 1;
    }
    .hero__ghost {
      opacity: 0.06;
    }
  }
</style>
