---
---
<section class="hero" id="top">
  <div class="hero__dots"></div>
  <div class="hero__ghost">INOUT</div>

  <div class="wrap hero__inner">
    <div class="hero__chip">
      <span class="dot"></span>
      Nuevo &middot; Asistente con IA + WhatsApp
    </div>

    <h1 class="hero__h1">
      &iquest;Sabes en qu&eacute; <span class="accent">gastas</span><br />tu sueldo?
    </h1>

    <p class="hero__sub">
      INOUT te muestra exactamente cuanto entra y cuanto sale. Mandale una foto del recibo por WhatsApp o pidele a la IA que registre por ti &mdash; cada sol contado, sin abrir la app.
    </p>

    <div class="hero__ctas">
      <a href="#descargar" class="btn btn--green">
        Descargar gratis <i data-lucide="arrow-right"></i>
      </a>
      <a href="#producto" class="btn btn--ghost-on-dark">Ver demo</a>
    </div>

    <div class="hero__stats">
      <div class="hero__stat">
        <div class="num">100<span class="num__pct">%</span></div>
        <div class="lbl">Gratis</div>
      </div>
      <div class="hero__stat">
        <div class="num green">&lt; 30s</div>
        <div class="lbl">Por registro</div>
      </div>
      <div class="hero__stat">
        <div class="num">0</div>
        <div class="lbl">Comisiones</div>
      </div>
      <div class="hero__stat">
        <div class="num green">IA</div>
        <div class="lbl">Asistente integrado</div>
      </div>
    </div>
  </div>

  <div class="hero__cue" aria-hidden="true">
    Scroll
    <span class="arrow"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-ink);
    color: var(--color-white-pure);
    overflow: hidden;
    padding: clamp(72px, 11vw, 140px) 0 clamp(96px, 14vw, 160px);
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 980px;
  }
  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 32px;
    padding: 0 14px;
    border: 1px solid var(--color-white-15);
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white-60);
    margin-bottom: 36px;
  }
  .hero__chip .dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary-green);
    border-radius: 999px;
  }
  .hero__h1 {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(56px, 9.5vw, 132px);
    line-height: 0.92;
    letter-spacing: -0.035em;
    margin: 0;
    text-wrap: balance;
    color: var(--color-white-pure);
  }
  .hero__h1 .accent {
    color: var(--color-primary-green);
  }
  .hero__sub {
    margin-top: 36px;
    max-width: 600px;
    font-size: clamp(17px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--color-white-60);
  }
  .hero__ctas {
    margin-top: 44px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero__ghost {
    position: absolute;
    right: -2vw;
    bottom: -8%;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(280px, 38vw, 540px);
    line-height: 0.78;
    color: var(--color-white-pure);
    opacity: 0.05;
    pointer-events: none;
    letter-spacing: -0.02em;
    user-select: none;
    z-index: 1;
  }
  .hero__dots {
    position: absolute;
    top: 64px;
    right: var(--gutter);
    width: 140px;
    height: 140px;
    background-image: radial-gradient(rgba(255, 255, 255, 0.18) 1.5px, transparent 1.6px);
    background-size: 14px 14px;
    opacity: 0.6;
    pointer-events: none;
    z-index: 1;
  }
  @media (max-width: 720px) {
    .hero__dots { display: none; }
  }

  .hero__stats {
    position: relative;
    z-index: 2;
    margin-top: clamp(56px, 9vw, 96px);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--color-white-15);
  }
  .hero__stat { padding: 28px 0 0; }
  .hero__stat + .hero__stat {
    border-left: 1px solid var(--color-white-15);
    padding-left: 28px;
  }
  .hero__stat .num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1;
    color: var(--color-white-pure);
  }
  .hero__stat .num.green { color: var(--color-primary-green); }
  .hero__stat .num__pct {
    color: var(--color-white-60);
    font-size: 0.5em;
  }
  .hero__stat .lbl {
    margin-top: 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white-60);
  }
  @media (max-width: 820px) {
    .hero__stats {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 28px;
    }
    .hero__stat + .hero__stat {
      border-left: 0;
      padding-left: 0;
    }
    .hero__stat:nth-child(2) {
      border-left: 1px solid var(--color-white-15);
      padding-left: 24px;
    }
    .hero__stat:nth-child(4) {
      border-left: 1px solid var(--color-white-15);
      padding-left: 24px;
    }
  }

  /* Staggered entry */
  .hero__chip,
  .hero__h1,
  .hero__sub,
  .hero__ctas,
  .hero__stats {
    opacity: 0;
    animation: inout-rise 720ms var(--ease-out) forwards;
  }
  .hero__chip   { animation-delay: 60ms; }
  .hero__h1     { animation-delay: 140ms; }
  .hero__sub    { animation-delay: 320ms; }
  .hero__ctas   { animation-delay: 440ms; }
  .hero__stats  { animation-delay: 560ms; }

  .hero__ghost {
    opacity: 0.05;
    animation:
      inout-ghost-in 1400ms var(--ease-out) 200ms both,
      inout-drift 22s var(--ease-in-out) 200ms infinite;
  }
  .hero__chip .dot {
    animation: inout-blink 1.6s var(--ease-in-out) infinite;
  }

  .hero__cue {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: var(--color-white-60);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    animation: inout-fade 1s var(--ease-out) 900ms both;
  }
  .hero__cue .arrow {
    width: 1px;
    height: 36px;
    background: var(--color-white-15);
    position: relative;
    animation: inout-bounce-down 1.8s var(--ease-in-out) infinite;
  }
  .hero__cue .arrow::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 7px;
    height: 7px;
    border-right: 1px solid var(--color-white-60);
    border-bottom: 1px solid var(--color-white-60);
    transform: translateX(-50%) rotate(45deg);
  }
  @media (max-width: 720px) {
    .hero__cue { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__chip,
    .hero__h1,
    .hero__sub,
    .hero__ctas,
    .hero__stats,
    .hero__cue { opacity: 1; }
    .hero__ghost { opacity: 0.05; }
  }
</style>
