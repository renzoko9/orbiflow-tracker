---
---
<header class="nav">
  <div class="wrap nav__inner">
    <a class="brand" href="#top" aria-label="INOUT">
      <img src="/logo-mark.svg" alt="" class="brand__logo" />
      <span>INOUT</span>
    </a>
    <nav class="nav__links">
      <a href="#producto">Producto</a>
      <a href="#otto">Otto</a>
      <a href="#insights">Insights</a>
      <a href="#como">Como funciona</a>
      <a href="#faq">FAQ</a>
    </nav>
    <div class="nav__cta">
      <a href="#proximamente" class="nav__pill">
        <span class="dot"></span>
        Disponible 1 jul
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-navy);
    border-bottom: 1px solid transparent;
    color: var(--color-white);
    transition:
      background 200ms var(--ease-out),
      border-color 200ms var(--ease-out),
      backdrop-filter 200ms var(--ease-out);
  }
  .nav.is-scrolled {
    background: rgba(15, 26, 61, 0.82);
    backdrop-filter: saturate(160%) blur(18px);
    -webkit-backdrop-filter: saturate(160%) blur(18px);
    border-bottom-color: var(--color-white-15);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 800;
    letter-spacing: -0.01em;
    font-size: 18px;
    color: var(--color-white);
  }
  .brand__logo {
    height: 28px;
    width: auto;
    display: block;
  }
  .nav__links {
    display: flex;
    gap: 30px;
    align-items: center;
  }
  .nav__links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-white-60);
    transition: color 120ms var(--ease-out);
  }
  .nav__links a:hover {
    color: var(--color-white);
  }
  .nav__cta {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .nav__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 38px;
    padding: 0 16px;
    border-radius: 12px;
    border: 1px solid var(--color-white-15);
    background: var(--color-white-10);
    color: var(--color-white);
    font-size: 13px;
    font-weight: 600;
    transition: border-color 140ms var(--ease-out), transform 140ms var(--ease-out);
  }
  .nav__pill:hover { border-color: var(--color-green); transform: translateY(-1px); }
  .nav__pill .dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--color-green);
    animation: inout-blink 1.6s var(--ease-in-out) infinite;
  }
  @media (max-width: 820px) {
    .nav__links {
      display: none;
    }
  }
</style>
